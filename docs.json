{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MPB Feather Design System",
  "appearance": {
    "default": "light",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0B002B"
    }
  },
  "colors": {
    "primary": "#FF18BD",
    "light": "#FF18BD",
    "dark": "#0B002B"
  },
  "fonts": {
    "heading": {
      "family": "SuisseIntl",
      "source": "/fonts/SuisseIntl-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "SuisseIntl",
      "source": "/fonts/SuisseIntl-Book.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Welcome",
        "pages": [
          "pages/welcome/principles",
          "pages/welcome/onboarding/for-designers",
          "pages/welcome/onboarding/for-engineers",
          "pages/welcome/design-system-workflow",
          "pages/welcome/component-status"
        ]
      },
      {
        "tab": "Foundations",
        "pages": ["pages/foundations/settings"]
      },
      {
        "tab": "Base components",
        "pages": ["pages/baseComponents/settings"]
      },
      {
        "tab": "Feature components",
        "pages": ["pages/featureComponents/settings"]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["pages/api-reference/introduction"]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "pages/api-reference/endpoint/get",
              "pages/api-reference/endpoint/create",
              "pages/api-reference/endpoint/delete",
              "pages/api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "pages": [
          "pages/resources/figma",
          "pages/resources/storybook",
          "pages/resources/resell",
          "pages/resources/reserve"
        ]
      },
      {
        "tab": "Boilerplate",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "pages/welcome/setting-up",
              "pages/welcome/principles",
              "index",
              "boilerplatePages/quickstart",
              "boilerplatePages/development"
            ]
          },
          {
            "group": "Onboarding",
            "pages": [
              "pages/welcome/onboarding/for-designers",
              "pages/welcome/onboarding/for-engineers"
            ]
          },
          {
            "group": "Updates",
            "pages": ["pages/welcome/component-status"]
          },
          {
            "group": "Customization",
            "pages": [
              "pages/essentials/settings",
              "pages/essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "pages/essentials/markdown",
              "pages/essentials/code",
              "pages/essentials/images",
              "pages/essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "pages/ai-tools/cursor",
              "pages/ai-tools/claude-code",
              "pages/ai-tools/windsurf"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:jon.quayle@.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
